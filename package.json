{
  "name": "flicky-cricket",
  "version": "1.0.0",
  "description": "Flicky Cricket - mobile cricket game",
  "scripts": {
    "build": "cp flicky-cricket.html www/index.html",
    "sync": "npm run build && npx cap sync",
    "open:ios": "npm run sync && npx cap open ios",
    "open:android": "npm run sync && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
